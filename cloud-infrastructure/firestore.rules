rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tareas pendientes — solo el propietario puede leer y modificar las suyas
    match /tareas_pendientes/{tareaId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow read, update, delete: if request.auth != null
                                  && request.auth.uid == resource.data.uid;
    }

    // Resultados — solo lectura del propietario
    match /resultados/{resultadoId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // Datos de usuario (créditos, plan)
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Pagos pendientes — el usuario crea y lee los suyos; el backend borra vía Admin SDK
    match /pagos_pendientes/{pagoId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read:   if request.auth != null && request.auth.uid == resource.data.uid;
      allow update, delete: if false;
    }

    // Historial de pagos — solo lectura del propietario
    match /pagos/{pagoId} {
      allow read:  if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // Leads institucionales — cualquier usuario autenticado puede crear (no leer)
    match /leads_institucionales/{leadId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
