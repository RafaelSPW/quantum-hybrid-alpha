rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function esAuth() {
      return request.auth != null;
    }
    function esAdmin() {
      return esAuth() && request.auth.token.email == "rafaelnunezinzaurralde@gmail.com";
    }

    // ── Tareas pendientes ──────────────────────────────────────────────────────
    match /tareas_pendientes/{tareaId} {
      allow create: if esAuth()
                    && request.auth.uid == request.resource.data.uid
                    && (request.resource.data.tipo != "generar_articulo" || esAdmin());
      allow read, update: if esAuth()
                          && request.auth.uid == resource.data.uid;
      allow delete: if false;
    }

    // ── Artículos (blog / recursos) ────────────────────────────────────────────
    match /articulos/{artId} {
      allow read:   if resource.data.publicado == true || esAdmin();
      allow create, update, delete: if esAdmin();
    }

    // ── Resultados (colección legacy, por si acaso) ────────────────────────────
    match /resultados/{resultadoId} {
      allow read:  if esAuth() && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // ── Perfil de usuario (créditos, plan, trial) ──────────────────────────────
    // El usuario puede leer y escribir solo su propio doc.
    // El primer registro lo crea el propio usuario al aceptar T&C.
    match /usuarios/{uid} {
      allow read, write: if esAuth() && request.auth.uid == uid;
    }

    // ── Pagos pendientes ───────────────────────────────────────────────────────
    // El usuario crea el doc tras capturar el pago PayPal.
    // El backend lo actualiza/borra via Admin SDK.
    match /pagos_pendientes/{pagoId} {
      allow create: if esAuth() && request.auth.uid == request.resource.data.uid;
      allow read:   if esAuth() && request.auth.uid == resource.data.uid;
      allow update, delete: if false;
    }

    // ── Historial de pagos — solo lectura del propietario ──────────────────────
    match /pagos/{pagoId} {
      allow read:  if esAuth() && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // ── Leads institucionales — cualquier usuario autenticado puede crear ───────
    match /leads_institucionales/{leadId} {
      allow create: if esAuth();
      allow read, update, delete: if false;
    }

    // ── Consultas de consultoría — público puede crear, solo admin lee ────────
    match /consultas/{docId} {
      allow create: if true;
      allow read, update, delete: if esAdmin();
    }

    // ── Feedback de usuarios (moderado antes de publicar) ─────────────────────
    // El usuario crea con aprobado=false. Solo el backend (Admin SDK) puede aprobar.
    // Lectura pública para mostrar testimonios en landing.
    match /feedback/{docId} {
      allow create: if esAuth()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.aprobado == false;
      allow read:   if true;
      allow update, delete: if false;
    }
  }
}
