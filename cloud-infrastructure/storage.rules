rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function esAutenticado() {
      return request.auth != null;
    }

    function esPropietario(uid) {
      return request.auth.uid == uid;
    }

    function tipoPermitido() {
      return request.resource.contentType in [
        'application/pdf',
        'image/jpeg',
        'image/png'
      ];
    }

    // ── Archivos de usuario — cubre TODOS los módulos ──────────────────────────
    // Patrón universal: {coleccion}/{uid}/{resto...}
    // Ejemplos cubiertos:
    //   documentos/{uid}/{tareaId}/{filename}
    //   documentos_forense/{uid}/{tareaId}/{filename}
    //   contratos/{uid}/{tareaId}/{filename}
    //   chat_docs/{uid}/{convId}/{filename}
    //   users/{uid}/fondos/{filename}
    //   cualquier módulo nuevo que use este patrón
    // Límite: 25 MB (el máximo necesario; contratos pueden ser PDFs extensos)

    match /{collection}/{uid}/{rest=**} {
      allow read:  if esAutenticado() && esPropietario(uid);
      allow write: if esAutenticado()
                   && esPropietario(uid)
                   && tipoPermitido()
                   && request.resource.size <= 25 * 1024 * 1024;
    }

    // ── Listas de sanciones y config — solo administrador ─────────────────────
    // Path: ofac/{file}   — XMLs de OFAC (SDN, Consolidated) y ONU
    // Path: config/{file} — Archivos de configuración (matriz_riesgo_config.json)
    // Cloud Run usa Firebase Admin SDK (bypassa estas reglas para lectura).
    // Estas rutas son de un solo segmento: NO coinciden con la regla de usuario.

    // UID del administrador: lVkD2tQbe7Y8FZuCudrgRZrUyOG2
    match /ofac/{file} {
      allow read, write: if request.auth != null
                         && request.auth.uid == "lVkD2tQbe7Y8FZuCudrgRZrUyOG2";
    }

    match /config/{file} {
      allow read, write: if request.auth != null
                         && request.auth.uid == "lVkD2tQbe7Y8FZuCudrgRZrUyOG2";
    }

    // ── Bloqueo explícito de todo lo demás ─────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
